# Copy this file to .env and fill in values
# cp .env.template .env

# Database
DATABASE_URL=sqlite:///./database/deepfake_detector.db

# File storage directories
UPLOAD_DIR=uploads
THUMBNAIL_DIR=thumbnails

# File size limit in bytes (500 MB)
MAX_FILE_SIZE=524288000

# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/png,video/mp4,video/avi,video/quicktime

# ML model weights path (filled in by ML team)
MODEL_WEIGHTS_PATH=models/deepfake_detector.pth
